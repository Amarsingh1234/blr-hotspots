# Neon Postgres connection string (required for API + ingest)
# Get from: Neon dashboard → Connection details → copy pooled or direct URL
# Use quotes if the password contains special characters (&, #, etc.)
DATABASE_URL='postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require'

# Local API port (optional)
BLR_PORT=8001

# Frontend (web/.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:8001
